Here's the code written in the modified c++ used for arduinos:
CODE STARTS::
int firstled = 13;
int secondled = 12;
int thirdled = 8
int j; //variable for "for" loops later
int loops = 3;


void setup() {
  // put your setup code here, to run once:
pinMode (firstled,OUTPUT);
pinMode(secondled,OUTPUT);
pinMode(thirdled,OUTPUT);
}

void loop() {
digitalWrite(13,HIGH);
delay(1000);
digitalWrite(13,LOW);
delay(1000);
digitalWrite(12,HIGH);
delay(1000);
digitalWrite(12,LOW);
delay(1000);
digitalWrite(8,HIGH);
delay(1000);
digitalWrite(8,LOW);
delay(1000);
digitalWrite(13,HIGH);
digitalWrite(12,HIGH);
digitalWrite(8,HIGH);
delay(1500);
digitalWrite(13,LOW);
digitalWrite(12,LOW);
digitalWrite(8,LOW);
delay(500);
//this loop makes it so that the code in the clause is repeated until
j = loops which currently equals to 3 meaning the code will loop 
three times before sequentially moving on.
for (j=1;j<=loops;j+1)
{
digitalWrite(8,HIGH);
delay(200);
digitalWrite(8,LOW);
delay(200);
}
for (j=1;j<=loops;j+1)
{
digitalWrite(12,HIGH);
delay(200);
digitalWrite(12,LOW);
delay(200);
}
for (j=1;j<=loops;j+1)
{
digitalWrite(13,HIGH);
delay(200);
digitalWrite(13,LOW);
delay(200);
}
}
